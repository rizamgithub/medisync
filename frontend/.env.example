# Base URLs of the deployed Function Apps.
#
# NEXT_PUBLIC_* variables are inlined into the static export at BUILD time —
# set these before `pnpm build`. Copy to `.env.local` for local development.
#
# Local dev defaults assume each service runs under `func start`:
#   match     -> :7071
#   inventory -> :7072
NEXT_PUBLIC_MATCH_API_URL=http://localhost:7071
NEXT_PUBLIC_INVENTORY_API_URL=http://localhost:7072
