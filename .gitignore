# Secrets — NEVER commit
.env
.env.*
!.env.example
*_accessKeys.csv
*access_key*
*AccessKey*
*secret*
*Secret*
*.pem
*.key
aws-credentials*

# Local scratchpad / screenshots / personal notes
.temp/
.scratch/
*.local.md

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/

# Azure Functions
local.settings.json

# Vendored shared package — source of truth is packages/shared/;
# (re)created by scripts/sync-shared.ps1
services/*/medisync_shared/

# Node / Next.js
node_modules/
.next/
out/
.turbo/

# BA diagram render — intermediate .mmd files (SVGs ARE committed for portability)
docs/ba/**/flows/*.mmd

# Terraform
.terraform/
# .terraform.lock.hcl IS committed on purpose — it pins exact provider
# versions + checksums so CI and laptops resolve identical providers.
*.tfstate
*.tfstate.*
*.tfplan
crash.log
*.tfvars
!*.tfvars.example

# IDE / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
desktop.ini

# Build / coverage
coverage/
htmlcov/
.coverage
*.log
